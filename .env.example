# Copy to `.env` (gitignored) and set your proxy. The Makefile loads `.env` and
# exports these so cross build containers can download Zig from ziglang.org.
# Only needed when the container has no direct internet (e.g. behind a proxy).
HTTP_PROXY=http://proxy.example:8080
HTTPS_PROXY=http://proxy.example:8080
http_proxy=http://proxy.example:8080
https_proxy=http://proxy.example:8080
