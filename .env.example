# Copy to `.env` (gitignored) and set your proxy. `make cross-arm`/`make win`
# then route both cross stages through it: the crates fetch (via Cross.toml
# passthrough) and the Zig download in `docker build` (via a generated
# DOCKER_CONFIG). Leave unset and everything runs direct. CI is unaffected.
HTTP_PROXY=http://proxy.example:8080
HTTPS_PROXY=http://proxy.example:8080
http_proxy=http://proxy.example:8080
https_proxy=http://proxy.example:8080
